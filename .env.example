# Required for OpenRouter upstream
OPENROUTER_API_KEY=

# Optional upstream providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NVIDIA_API_KEY=

# Optional gateway/runtime tuning
# GATEWAY_PORT=8090
# GATEWAY_MAX_OUTPUT_TOKENS=1024
# GATEWAY_429_RETRIES=2
# PROVIDER_ID=openrouter  (default: inferred from MODEL_ID prefix via MODEL_ROUTES)
# MODEL_ID=nvidia/nemotron-3-super-120b-a12b:free
# OPENCLAW_VERSION=2026.3.11
